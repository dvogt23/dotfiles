[general]
ui = ttyui
accounts = Gmail, Outlook

# Path to file with arbitrary Python code to be loaded
pythonfile = ~/.offlineimap.py

[Account Outlook]
localrepository = Outlook-Local
remoterepository = Outlook-Remote

[Repository Outlook-Local]
type = Maildir
localfolders = ~/.mail/Outlook

[Repository Outlook-Remote]
type = IMAP
remotehost = imap-mail.outlook.com
remoteuser = divogt@live.de
remotepasseval = get_pass("outlook.com/divogt@live.de")
realdelete = no
maxconnections = 3
ssl_version=tls1_2
sslcacertfile = /etc/ssl/certs/ca-certificates.crt
copy_ignore_eval = lambda foldername: {'INBOX': [6796, 6798, 6800]}.get(foldername)

[Account Gmail]
localrepository = Gmail-Local
remoterepository = Gmail-Remote

[Repository Gmail-Local]
type = Maildir
localfolders = ~/.mail/Gmail

[Repository Gmail-Remote]
type = Gmail
remoteuser = mail2dima@gmail.com
remotepasseval = get_pass("Google/mail2dima@gmail.com-mutt")
realdelete = no
maxconnections = 3
ssl_version=tls1_2
sslcacertfile = /etc/ssl/certs/ca-certificates.crt
