set folder      = ~/.mail/Outlook
set spoolfile   = "+Inbox"
set mbox        = "+Inbox"
set postponed   = "+Drafts"
unset record

mailboxes   Outlook/+Inbox
            Outlook/+Sent
            Outlook/+Deleted
            Outlook/+Drafts

macro index D \
    "<save-message>+Deleted<enter>" \
    "move message to the trash"

macro index S \
    "<save-message>+Junk<enter>" \
    "mark message as spam"

# main options
set realname   = "D. Vogt"
set from       = "mail2dima@gmail.com"
set mail_check = 0
set envelope_from
